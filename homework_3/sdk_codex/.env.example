# Per-variant .env for sdk_codex/.
# Optional — if absent, the script falls back to ../.env (homework_2/.env)
# shared with no_sdk. Copy to .env and fill in your key if you want this
# variant to use a different account or model than no_sdk.

OPENAI_API_KEY=sk-...
